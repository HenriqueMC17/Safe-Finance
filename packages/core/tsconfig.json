{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "paths": {
      "@safe-finance/core/*": ["./*"]
    }
  },
  "include": ["entities/**/*", "use-cases/**/*", "index.ts"],
  "exclude": ["node_modules", "dist"]
}
