{
    "name":  "safe-finance-monorepo",
    "version":  "1.0.0",
    "private":  true,
    "packageManager":  "pnpm@11.1.1",
    "workspaces":  [
                       "apps/*",
                       "packages/*",
                       "packages/infrastructure/*"
                   ],
    "scripts":  {
                    "build":  "turbo run build",
                    "dev":  "turbo run dev",
                    "lint":  "turbo run lint",
                    "format":  "prettier --write \"**/*.{ts,tsx,md}\""
                },
    "devDependencies":  {
                            "turbo":  "^2.9.14",
                            "prettier":  "^3.0.0"
                        },
    "pnpm":  {
                 "onlyBuiltDependencies":  [
                                               "core-js",
                                               "esbuild",
                                               "sharp",
                                               "unrs-resolver"
                                           ]
             }
}
